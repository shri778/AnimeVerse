<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>AnimeVerse — Discover Every World</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet"/>
<style>
  :root {
    --bg:       #0a0a0f;
    --surface:  #12121a;
    --card:     #1a1a26;
    --border:   #2a2a3a;
    --accent:   #e84393;
    --accent2:  #7c3aed;
    --gold:     #f59e0b;
    --text:     #e8e8f0;
    --muted:    #6b6b80;
    --success:  #10b981;
    --r:        10px;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── NOISE OVERLAY ── */
  body::before {
    content: '';
    position: fixed; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none; z-index: 0; opacity: .4;
  }

  /* ── HEADER ── */
  header {
    position: sticky; top: 0; z-index: 100;
    background: rgba(10,10,15,.85);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    padding: 0 24px;
    display: flex; align-items: center; gap: 16px;
    height: 60px;
  }
  .logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    letter-spacing: 2px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    flex-shrink: 0;
  }
  .search-wrap {
    flex: 1; max-width: 480px; position: relative;
  }
  .search-wrap input {
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    padding: 9px 40px 9px 14px;
    outline: none;
    transition: border-color .2s;
  }
  .search-wrap input:focus { border-color: var(--accent); }
  .search-wrap .search-icon {
    position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
    color: var(--muted); font-size: 16px; pointer-events: none;
  }
  .nav-tabs {
    display: flex; gap: 4px; margin-left: auto;
  }
  .nav-tab {
    background: none; border: none; cursor: pointer;
    color: var(--muted); font-family: 'Inter', sans-serif;
    font-size: 13px; font-weight: 500;
    padding: 6px 14px; border-radius: 6px;
    transition: all .2s;
  }
  .nav-tab:hover { color: var(--text); background: var(--surface); }
  .nav-tab.active { color: var(--accent); background: rgba(232,67,147,.1); }
  .pin-count-badge {
    background: var(--accent);
    color: #fff; font-size: 10px; font-weight: 700;
    padding: 1px 5px; border-radius: 10px;
    margin-left: 4px; display: inline-block;
  }

  /* ── MAIN ── */
  main { position: relative; z-index: 1; padding: 24px; max-width: 1400px; margin: 0 auto; }

  /* ── HERO BANNER ── */
  .hero {
    background: linear-gradient(135deg, rgba(232,67,147,.15) 0%, rgba(124,58,237,.15) 100%);
    border: 1px solid var(--border);
    border-radius: var(--r);
    padding: 32px 40px;
    margin-bottom: 32px;
    display: flex; align-items: center; justify-content: space-between;
    gap: 24px;
    overflow: hidden; position: relative;
  }
  .hero::after {
    content: 'アニメ';
    position: absolute; right: -10px; top: 50%; transform: translateY(-50%);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 140px; color: rgba(255,255,255,.03);
    pointer-events: none; line-height: 1;
  }
  .hero h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(32px, 5vw, 56px);
    letter-spacing: 2px; line-height: 1;
    background: linear-gradient(135deg, #fff 30%, var(--accent));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  }
  .hero p { color: var(--muted); font-size: 14px; margin-top: 8px; max-width: 360px; }
  .hero-actions { display: flex; gap: 10px; margin-top: 20px; flex-wrap: wrap; }
  .btn {
    border: none; cursor: pointer; border-radius: 8px;
    font-family: 'Inter', sans-serif; font-weight: 600;
    font-size: 13px; padding: 10px 20px;
    transition: all .2s; display: inline-flex; align-items: center; gap: 6px;
  }
  .btn-primary { background: var(--accent); color: #fff; }
  .btn-primary:hover { background: #d63384; transform: translateY(-1px); }
  .btn-secondary { background: var(--surface); color: var(--text); border: 1px solid var(--border); }
  .btn-secondary:hover { border-color: var(--accent); color: var(--accent); }
  .notif-status {
    font-size: 12px; color: var(--muted);
    display: flex; align-items: center; gap: 6px; margin-top: 10px;
  }
  .notif-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--muted); }
  .notif-dot.on { background: var(--success); box-shadow: 0 0 6px var(--success); }

  /* ── SECTION ── */
  .section-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 16px;
  }
  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px; letter-spacing: 1px;
    display: flex; align-items: center; gap: 10px;
  }
  .section-title span { color: var(--accent); }

  /* ── FILTERS ── */
  .filter-bar {
    display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 24px;
  }
  .filter-chip {
    background: var(--surface); border: 1px solid var(--border);
    color: var(--muted); font-size: 12px; font-weight: 500;
    padding: 5px 14px; border-radius: 20px; cursor: pointer;
    transition: all .2s;
  }
  .filter-chip:hover, .filter-chip.active {
    border-color: var(--accent); color: var(--accent);
    background: rgba(232,67,147,.08);
  }

  /* ── GRID ── */
  .anime-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 16px;
  }

  /* ── CARD ── */
  .anime-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--r);
    overflow: hidden; cursor: pointer;
    transition: transform .2s, border-color .2s, box-shadow .2s;
    position: relative;
  }
  .anime-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
    box-shadow: 0 8px 32px rgba(232,67,147,.2);
  }
  .anime-card.pinned { border-color: var(--gold); }
  .anime-card.pinned:hover { border-color: var(--gold); box-shadow: 0 8px 32px rgba(245,158,11,.2); }

  .card-img-wrap { position: relative; aspect-ratio: 3/4; overflow: hidden; }
  .card-img-wrap img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform .3s;
  }
  .anime-card:hover .card-img-wrap img { transform: scale(1.05); }
  .card-score {
    position: absolute; top: 8px; left: 8px;
    background: rgba(0,0,0,.75); backdrop-filter: blur(4px);
    color: var(--gold); font-size: 12px; font-weight: 700;
    font-family: 'JetBrains Mono', monospace;
    padding: 3px 8px; border-radius: 6px;
    display: flex; align-items: center; gap: 4px;
  }
  .pin-btn {
    position: absolute; top: 8px; right: 8px;
    background: rgba(0,0,0,.75); backdrop-filter: blur(4px);
    border: none; border-radius: 6px; cursor: pointer;
    width: 30px; height: 30px;
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; transition: all .2s;
    color: var(--muted);
  }
  .pin-btn:hover { background: rgba(232,67,147,.3); color: var(--accent); }
  .pin-btn.pinned-active { color: var(--gold); background: rgba(245,158,11,.2); }

  .card-body { padding: 12px; }
  .card-title {
    font-size: 13px; font-weight: 600; line-height: 1.3;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden; margin-bottom: 6px;
  }
  .card-meta {
    display: flex; gap: 6px; flex-wrap: wrap;
  }
  .tag {
    font-size: 10px; font-weight: 600; text-transform: uppercase;
    letter-spacing: .5px; padding: 2px 7px; border-radius: 4px;
  }
  .tag-type { background: rgba(124,58,237,.2); color: #a78bfa; }
  .tag-ep   { background: rgba(16,185,129,.15); color: #34d399; }
  .tag-year { background: rgba(232,67,147,.1); color: #f472b6; }

  /* ── SKELETON ── */
  .skeleton {
    background: linear-gradient(90deg, var(--card) 25%, var(--surface) 50%, var(--card) 75%);
    background-size: 200% 100%;
    animation: shimmer 1.4s infinite;
    border-radius: var(--r);
  }
  @keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
  .skel-card { aspect-ratio: 3/4.8; }

  /* ── DETAIL MODAL ── */
  .modal-overlay {
    position: fixed; inset: 0; z-index: 200;
    background: rgba(0,0,0,.85); backdrop-filter: blur(8px);
    display: none; align-items: center; justify-content: center; padding: 20px;
  }
  .modal-overlay.open { display: flex; }
  .modal {
    background: var(--card); border: 1px solid var(--border);
    border-radius: 16px; max-width: 760px; width: 100%;
    max-height: 90vh; overflow-y: auto;
    animation: popIn .25s cubic-bezier(.34,1.56,.64,1);
  }
  @keyframes popIn { from{transform:scale(.9);opacity:0} to{transform:scale(1);opacity:1} }
  .modal-hero { position: relative; }
  .modal-banner {
    width: 100%; height: 220px; object-fit: cover;
    display: block; border-radius: 16px 16px 0 0;
    filter: brightness(.6);
  }
  .modal-poster {
    position: absolute; bottom: -40px; left: 24px;
    width: 90px; height: 130px; object-fit: cover;
    border-radius: 8px; border: 3px solid var(--card);
    box-shadow: 0 4px 20px rgba(0,0,0,.5);
  }
  .modal-close {
    position: absolute; top: 12px; right: 12px;
    background: rgba(0,0,0,.6); border: none; color: #fff;
    width: 32px; height: 32px; border-radius: 8px; cursor: pointer;
    font-size: 18px; display: flex; align-items: center; justify-content: center;
  }
  .modal-body { padding: 56px 24px 24px; }
  .modal-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 30px; letter-spacing: 1px; line-height: 1.1;
    margin-bottom: 4px;
  }
  .modal-subtitle { color: var(--muted); font-size: 13px; margin-bottom: 16px; }
  .modal-stats {
    display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 20px;
  }
  .stat { display: flex; flex-direction: column; gap: 2px; }
  .stat-val { font-size: 20px; font-weight: 700; font-family: 'JetBrains Mono', monospace; color: var(--accent); }
  .stat-key { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: .5px; }
  .modal-synopsis {
    font-size: 13px; color: var(--muted); line-height: 1.7;
    margin-bottom: 20px;
  }
  .modal-genres { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 24px; }
  .genre-chip {
    font-size: 11px; font-weight: 600;
    padding: 4px 10px; border-radius: 20px;
    background: rgba(124,58,237,.15); color: #a78bfa;
    border: 1px solid rgba(124,58,237,.3);
  }
  .modal-actions { display: flex; gap: 10px; flex-wrap: wrap; }
  .pin-full-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 20px; border-radius: 8px; border: none;
    font-family: 'Inter', sans-serif; font-weight: 600; font-size: 13px;
    cursor: pointer; transition: all .2s;
    background: var(--surface); color: var(--text); border: 1px solid var(--border);
  }
  .pin-full-btn.is-pinned { background: rgba(245,158,11,.15); color: var(--gold); border-color: var(--gold); }
  .pin-full-btn:hover { transform: translateY(-1px); }

  /* ── PINNED VIEW ── */
  #pins-view { display: none; }
  #pins-view.active { display: block; }
  #discover-view { display: block; }
  #discover-view.hidden { display: none; }

  .pinned-empty {
    text-align: center; padding: 80px 20px;
    color: var(--muted);
  }
  .pinned-empty .icon { font-size: 48px; margin-bottom: 12px; }
  .pinned-empty p { font-size: 14px; }

  /* ── TOAST ── */
  .toast-stack { position: fixed; bottom: 24px; right: 24px; z-index: 999; display: flex; flex-direction: column; gap: 8px; }
  .toast {
    background: var(--card); border: 1px solid var(--border);
    border-radius: 10px; padding: 12px 16px;
    display: flex; align-items: center; gap: 10px;
    font-size: 13px; min-width: 260px;
    animation: slideIn .3s ease;
    box-shadow: 0 4px 24px rgba(0,0,0,.4);
  }
  .toast.pin   { border-left: 3px solid var(--gold); }
  .toast.unpin { border-left: 3px solid var(--muted); }
  .toast.notif { border-left: 3px solid var(--success); }
  @keyframes slideIn { from{transform:translateX(100%);opacity:0} to{transform:translateX(0);opacity:1} }

  /* ── LOAD MORE ── */
  .load-more-wrap { text-align: center; margin-top: 32px; }

  /* ── RESPONSIVE ── */
  @media(max-width:600px){
    header { flex-wrap: wrap; height: auto; padding: 12px; gap: 10px; }
    .nav-tabs { width: 100%; justify-content: center; }
    .hero { padding: 24px; }
    .hero::after { display: none; }
    .anime-grid { grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 10px; }
    main { padding: 16px; }
  }
</style>
</head>
<body>

<!-- HEADER -->
<header>
  <div class="logo">AnimeVerse</div>
  <div class="search-wrap">
    <input type="text" id="searchInput" placeholder="Search any anime…" autocomplete="off"/>
    <span class="search-icon">🔍</span>
  </div>
  <nav class="nav-tabs">
    <button class="nav-tab active" onclick="showView('discover')">Discover</button>
    <button class="nav-tab" onclick="showView('pins')" id="pinsTab">
      Pinned <span class="pin-count-badge" id="pinBadge" style="display:none">0</span>
    </button>
  </nav>
</header>

<!-- MAIN -->
<main>

  <!-- DISCOVER VIEW -->
  <div id="discover-view">
    <!-- HERO -->
    <div class="hero">
      <div>
        <h1>Every Anime.<br/>One Universe.</h1>
        <p>Search, explore, and pin your favourites. Get notified whenever a new episode drops.</p>
        <div class="hero-actions">
          <button class="btn btn-primary" onclick="requestNotifPermission()">🔔 Enable Notifications</button>
          <button class="btn btn-secondary" onclick="scrollToGrid()">Browse All →</button>
        </div>
        <div class="notif-status">
          <div class="notif-dot" id="notifDot"></div>
          <span id="notifLabel">Notifications off</span>
        </div>
      </div>
    </div>

    <!-- FILTER BAR -->
    <div class="filter-bar" id="filterBar">
      <button class="filter-chip active" onclick="setFilter('trending', this)">🔥 Trending</button>
      <button class="filter-chip" onclick="setFilter('airing', this)">📺 Airing Now</button>
      <button class="filter-chip" onclick="setFilter('upcoming', this)">🚀 Upcoming</button>
      <button class="filter-chip" onclick="setFilter('popular', this)">⭐ All-Time Popular</button>
      <button class="filter-chip" onclick="setFilter('movie', this)">🎬 Movies</button>
    </div>

    <!-- GRID -->
    <div class="section-header">
      <div class="section-title" id="gridTitle">🔥 <span>Trending</span> This Season</div>
    </div>
    <div class="anime-grid" id="animeGrid"></div>
    <div class="load-more-wrap">
      <button class="btn btn-secondary" id="loadMoreBtn" onclick="loadMore()" style="display:none">Load More</button>
    </div>
  </div>

  <!-- PINS VIEW -->
  <div id="pins-view">
    <div class="section-header">
      <div class="section-title">📌 <span>Pinned</span> Anime</div>
    </div>
    <div id="pinnedGrid" class="anime-grid"></div>
    <div class="pinned-empty" id="pinnedEmpty" style="display:none">
      <div class="icon">📌</div>
      <p>No pinned anime yet.<br/>Browse and pin your favourites!</p>
    </div>
  </div>

</main>

<!-- MODAL -->
<div class="modal-overlay" id="modalOverlay" onclick="closeModal(event)">
  <div class="modal" id="modal">
    <div class="modal-hero">
      <img class="modal-banner" id="modalBanner" src="" alt=""/>
      <img class="modal-poster" id="modalPoster" src="" alt=""/>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-body">
      <div class="modal-title" id="modalTitle"></div>
      <div class="modal-subtitle" id="modalSubtitle"></div>
      <div class="modal-stats" id="modalStats"></div>
      <div class="modal-synopsis" id="modalSynopsis"></div>
      <div class="modal-genres" id="modalGenres"></div>
      <div class="modal-actions">
        <button class="pin-full-btn" id="modalPinBtn" onclick="togglePinFromModal()">📌 Pin Anime</button>
        <a id="modalMALLink" href="#" target="_blank" class="btn btn-secondary" style="text-decoration:none">View on MAL →</a>
      </div>
    </div>
  </div>
</div>

<!-- TOAST STACK -->
<div class="toast-stack" id="toastStack"></div>

<script>
// ── STATE ──
let pinnedIds  = JSON.parse(localStorage.getItem('av_pins') || '[]');
let currentFilter = 'trending';
let currentPage   = 1;
let currentAnime  = null;
let isLoading     = false;
let searchTimeout = null;
let allResults    = [];

// ── JIKAN API ──
const JIKAN = 'https://api.jikan.moe/v4';

async function jikanFetch(url) {
  const res = await fetch(url);
  if (!res.ok) throw new Error('API error');
  return res.json();
}

// ── FILTER → ENDPOINT ──
function getEndpoint(filter, page = 1) {
  const p = `&page=${page}&limit=20`;
  switch (filter) {
    case 'trending':  return `${JIKAN}/top/anime?filter=airing${p}`;
    case 'airing':    return `${JIKAN}/seasons/now?${p.slice(1)}`;
    case 'upcoming':  return `${JIKAN}/seasons/upcoming?${p.slice(1)}`;
    case 'popular':   return `${JIKAN}/top/anime?filter=bypopularity${p}`;
    case 'movie':     return `${JIKAN}/top/anime?type=movie${p}`;
    default:          return `${JIKAN}/top/anime?filter=airing${p}`;
  }
}

// ── RENDER GRID ──
function renderGrid(items, append = false) {
  const grid = document.getElementById('animeGrid');
  if (!append) grid.innerHTML = '';

  items.forEach(anime => {
    const pinned = pinnedIds.includes(anime.mal_id);
    const img    = anime.images?.jpg?.image_url || '';
    const score  = anime.score ? anime.score.toFixed(1) : '—';
    const type   = anime.type || '?';
    const eps    = anime.episodes ? `${anime.episodes} ep` : 'Ongoing';
    const year   = anime.year || anime.aired?.prop?.from?.year || '?';

    const card = document.createElement('div');
    card.className = `anime-card${pinned ? ' pinned' : ''}`;
    card.dataset.id = anime.mal_id;
    card.innerHTML = `
      <div class="card-img-wrap">
        <img src="${img}" alt="${anime.title}" loading="lazy" onerror="this.src='https://via.placeholder.com/200x280/1a1a26/6b6b80?text=No+Image'"/>
        <div class="card-score">⭐ ${score}</div>
        <button class="pin-btn ${pinned ? 'pinned-active' : ''}" onclick="event.stopPropagation(); togglePin(${anime.mal_id}, this)" title="${pinned ? 'Unpin' : 'Pin'}">
          ${pinned ? '📌' : '🔖'}
        </button>
      </div>
      <div class="card-body">
        <div class="card-title">${anime.title}</div>
        <div class="card-meta">
          <span class="tag tag-type">${type}</span>
          <span class="tag tag-ep">${eps}</span>
          <span class="tag tag-year">${year}</span>
        </div>
      </div>`;
    card.onclick = () => openModal(anime);
    grid.appendChild(card);
  });
}

// ── SKELETON ──
function showSkeleton(count = 20) {
  const grid = document.getElementById('animeGrid');
  grid.innerHTML = '';
  for (let i = 0; i < count; i++) {
    const s = document.createElement('div');
    s.className = 'skeleton skel-card';
    grid.appendChild(s);
  }
}

// ── LOAD DATA ──
async function loadAnime(filter = currentFilter, page = 1, append = false) {
  if (isLoading) return;
  isLoading = true;
  if (!append) showSkeleton();
  try {
    const data = await jikanFetch(getEndpoint(filter, page));
    allResults = append ? [...allResults, ...(data.data || [])] : (data.data || []);
    renderGrid(data.data || [], append);
    const btn = document.getElementById('loadMoreBtn');
    btn.style.display = data.pagination?.has_next_page ? 'inline-flex' : 'none';
  } catch (e) {
    document.getElementById('animeGrid').innerHTML = '<p style="color:var(--muted);padding:40px;grid-column:1/-1;text-align:center">Failed to load. Check your connection.</p>';
  }
  isLoading = false;
}

function loadMore() {
  currentPage++;
  loadAnime(currentFilter, currentPage, true);
}

// ── FILTER ──
function setFilter(f, el) {
  currentFilter = f;
  currentPage   = 1;
  document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  const titles = {
    trending: '🔥 <span>Trending</span> This Season',
    airing:   '📺 <span>Airing</span> Now',
    upcoming: '🚀 <span>Upcoming</span> Anime',
    popular:  '⭐ <span>All-Time</span> Popular',
    movie:    '🎬 Top <span>Movies</span>'
  };
  document.getElementById('gridTitle').innerHTML = titles[f] || '';
  document.getElementById('searchInput').value = '';
  loadAnime(f, 1, false);
}

// ── SEARCH ──
document.getElementById('searchInput').addEventListener('input', e => {
  clearTimeout(searchTimeout);
  const q = e.target.value.trim();
  if (!q) { loadAnime(currentFilter, 1, false); return; }
  searchTimeout = setTimeout(async () => {
    showSkeleton(12);
    try {
      const data = await jikanFetch(`${JIKAN}/anime?q=${encodeURIComponent(q)}&limit=20&sfw=true`);
      document.getElementById('gridTitle').innerHTML = `🔍 Results for <span>"${q}"</span>`;
      renderGrid(data.data || []);
      document.getElementById('loadMoreBtn').style.display = 'none';
    } catch { }
  }, 500);
});

// ── PIN / UNPIN ──
function togglePin(malId, btnEl = null) {
  const idx    = pinnedIds.indexOf(malId);
  const adding = idx === -1;

  if (adding) pinnedIds.push(malId);
  else pinnedIds.splice(idx, 1);

  localStorage.setItem('av_pins', JSON.stringify(pinnedIds));
  updatePinBadge();

  // Update card visuals
  const card = document.querySelector(`.anime-card[data-id="${malId}"]`);
  if (card) {
    card.classList.toggle('pinned', adding);
    const pb = card.querySelector('.pin-btn');
    if (pb) {
      pb.classList.toggle('pinned-active', adding);
      pb.textContent = adding ? '📌' : '🔖';
    }
  }

  // Update modal button if open
  if (currentAnime?.mal_id === malId) syncModalPin();

  // Toast
  showToast(adding ? '📌' : '🗑️', adding ? `<b>${getAnimeTitle(malId)}</b> pinned!` : `<b>${getAnimeTitle(malId)}</b> unpinned`, adding ? 'pin' : 'unpin');

  // Browser notification
  if (adding) sendPinNotification(malId);

  // Refresh pinned view if open
  if (document.getElementById('pins-view').classList.contains('active')) renderPinnedView();
}

function togglePinFromModal() {
  if (!currentAnime) return;
  togglePin(currentAnime.mal_id);
}

function syncModalPin() {
  const btn = document.getElementById('modalPinBtn');
  const pinned = pinnedIds.includes(currentAnime?.mal_id);
  btn.className = `pin-full-btn${pinned ? ' is-pinned' : ''}`;
  btn.textContent = pinned ? '📌 Pinned' : '📌 Pin Anime';
}

// Store last-seen anime data for notifications
const animeCache = {};
function cacheAnime(anime) { animeCache[anime.mal_id] = anime; }
function getAnimeTitle(malId) { return animeCache[malId]?.title || 'Anime'; }

// ── MODAL ──
function openModal(anime) {
  cacheAnime(anime);
  currentAnime = anime;
  const img    = anime.images?.jpg?.large_image_url || anime.images?.jpg?.image_url || '';
  document.getElementById('modalBanner').src = img;
  document.getElementById('modalPoster').src = img;
  document.getElementById('modalTitle').textContent = anime.title;
  document.getElementById('modalSubtitle').textContent = [anime.title_english, anime.title_japanese].filter(Boolean).join(' · ') || '';

  const score = anime.score ? `${anime.score}/10` : 'N/A';
  const rank  = anime.rank  ? `#${anime.rank}`   : 'N/A';
  const popul = anime.popularity ? `#${anime.popularity}` : 'N/A';
  const eps   = anime.episodes || '?';
  document.getElementById('modalStats').innerHTML = `
    <div class="stat"><div class="stat-val">${score}</div><div class="stat-key">Score</div></div>
    <div class="stat"><div class="stat-val">${rank}</div><div class="stat-key">Rank</div></div>
    <div class="stat"><div class="stat-val">${popul}</div><div class="stat-key">Popularity</div></div>
    <div class="stat"><div class="stat-val">${eps}</div><div class="stat-key">Episodes</div></div>
  `;
  document.getElementById('modalSynopsis').textContent = anime.synopsis?.slice(0,400) + (anime.synopsis?.length > 400 ? '…' : '') || 'No synopsis available.';

  const genres = (anime.genres || []).map(g => `<span class="genre-chip">${g.name}</span>`).join('');
  document.getElementById('modalGenres').innerHTML = genres;
  document.getElementById('modalMALLink').href = anime.url || '#';

  syncModalPin();
  document.getElementById('modalOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal(e) {
  if (e && e.target !== document.getElementById('modalOverlay')) return;
  document.getElementById('modalOverlay').classList.remove('open');
  document.body.style.overflow = '';
  currentAnime = null;
}

// ── PINNED VIEW ──
function renderPinnedView() {
  const grid  = document.getElementById('pinnedGrid');
  const empty = document.getElementById('pinnedEmpty');
  grid.innerHTML = '';
  if (pinnedIds.length === 0) {
    empty.style.display = 'block'; return;
  }
  empty.style.display = 'none';
  const cached = pinnedIds.map(id => animeCache[id]).filter(Boolean);
  renderGridInto(cached, grid);
}

function renderGridInto(items, container) {
  items.forEach(anime => {
    if (!anime) return;
    const pinned = pinnedIds.includes(anime.mal_id);
    const img    = anime.images?.jpg?.image_url || '';
    const score  = anime.score ? anime.score.toFixed(1) : '—';
    const card   = document.createElement('div');
    card.className = `anime-card${pinned ? ' pinned' : ''}`;
    card.dataset.id = anime.mal_id;
    card.innerHTML = `
      <div class="card-img-wrap">
        <img src="${img}" alt="${anime.title}" loading="lazy"/>
        <div class="card-score">⭐ ${score}</div>
        <button class="pin-btn ${pinned ? 'pinned-active' : ''}" onclick="event.stopPropagation(); togglePin(${anime.mal_id}, this)">
          ${pinned ? '📌' : '🔖'}
        </button>
      </div>
      <div class="card-body">
        <div class="card-title">${anime.title}</div>
        <div class="card-meta">
          <span class="tag tag-type">${anime.type || '?'}</span>
        </div>
      </div>`;
    card.onclick = () => openModal(anime);
    container.appendChild(card);
  });
}

// ── VIEWS ──
function showView(v) {
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  const discoverView = document.getElementById('discover-view');
  const pinsView     = document.getElementById('pins-view');
  if (v === 'discover') {
    discoverView.classList.remove('hidden');
    pinsView.classList.remove('active');
    document.querySelectorAll('.nav-tab')[0].classList.add('active');
  } else {
    discoverView.classList.add('hidden');
    pinsView.classList.add('active');
    document.querySelectorAll('.nav-tab')[1].classList.add('active');
    renderPinnedView();
  }
}

// ── PIN BADGE ──
function updatePinBadge() {
  const badge = document.getElementById('pinBadge');
  if (pinnedIds.length > 0) {
    badge.style.display = 'inline-block';
    badge.textContent   = pinnedIds.length;
  } else {
    badge.style.display = 'none';
  }
}

// ── NOTIFICATIONS ──
function updateNotifUI(perm) {
  const dot   = document.getElementById('notifDot');
  const label = document.getElementById('notifLabel');
  if (perm === 'granted') {
    dot.classList.add('on');
    label.textContent = 'Notifications enabled ✓';
  } else if (perm === 'denied') {
    dot.classList.remove('on');
    label.textContent = 'Notifications blocked — allow in browser settings';
  } else {
    dot.classList.remove('on');
    label.textContent = 'Notifications off';
  }
}

async function requestNotifPermission() {
  if (!('Notification' in window)) {
    showToast('⚠️', 'Your browser does not support notifications', 'notif');
    return;
  }
  const perm = await Notification.requestPermission();
  updateNotifUI(perm);
  if (perm === 'granted') {
    showToast('🔔', 'Notifications enabled! Pin an anime to get updates.', 'notif');
  }
}

function sendPinNotification(malId) {
  if (Notification.permission !== 'granted') return;
  const anime = animeCache[malId];
  if (!anime) return;
  const n = new Notification('📌 AnimeVerse — Anime Pinned!', {
    body: `You pinned "${anime.title}". We'll notify you about new episodes!`,
    icon: anime.images?.jpg?.image_url || '',
    badge: anime.images?.jpg?.small_image_url || '',
    tag: `pin-${malId}`
  });
  n.onclick = () => { window.focus(); n.close(); };
}

// ── TOAST ──
function showToast(icon, msg, type = '') {
  const stack = document.getElementById('toastStack');
  const t = document.createElement('div');
  t.className = `toast ${type}`;
  t.innerHTML = `<span>${icon}</span><span>${msg}</span>`;
  stack.appendChild(t);
  setTimeout(() => { t.style.opacity = '0'; t.style.transform = 'translateX(100%)'; t.style.transition = '.3s'; setTimeout(() => t.remove(), 300); }, 3000);
}

// ── SCROLL TO GRID ──
function scrollToGrid() {
  document.getElementById('animeGrid').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

// ── INIT ──
updateNotifUI(Notification?.permission || 'default');
updatePinBadge();
loadAnime('trending', 1, false);
</script>
